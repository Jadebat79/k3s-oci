# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars.

tenancy_ocid     = "ocid1.tenancy.oc1..aaaa..."
user_ocid        = "ocid1.user.oc1..aaaa..."
fingerprint      = "12:34:56:78:90:ab:cd:ef:..."
private_key      = <<EOT
-----BEGIN PRIVATE KEY-----
...paste-your-oci-api-private-key...
-----END PRIVATE KEY-----
EOT
region           = "eu-frankfurt-1"
compartment_ocid = "ocid1.compartment.oc1..aaaa..." # k3-staging (where VMs are created)

# --- Existing bare VCN (no subnet/IGW yet) ---
use_existing_vcn     = true
existing_vcn_ocid    = "ocid1.vcn.oc1..aaaa..."          # your existing VCN
vcn_compartment_ocid = "ocid1.compartment.oc1..bbbb..." # compartment that owns the VCN
subnet_cidr          = "10.0.1.0/24"                   # must fit inside the VCN CIDR
# existing_internet_gateway_id = ""                    # leave empty — Terraform creates IGW + subnet + security list + route table
# existing_subnet_ocid         = ""                    # leave empty unless you already have a subnet to reuse

ssh_public_key      = "ssh-ed25519 AAAA... yourname@host"
ssh_allowed_cidr    = "0.0.0.0/0"

# 3 nodes total = 1 server + 2 agents, each 1 OCPU / 6 GB (= 3 OCPU / 18 GB).
# If capped at 2 OCPU / 12 GB, set agent_count = 1 (2 nodes total).
agent_count         = 2
instance_ocpus      = 1
instance_memory_gbs = 6

expose_http = true
