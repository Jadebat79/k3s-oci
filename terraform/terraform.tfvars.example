# Copy to terraform.tfvars and fill in. Do NOT commit terraform.tfvars.

tenancy_ocid     = "ocid1.tenancy.oc1..aaaa..."
user_ocid        = "ocid1.user.oc1..aaaa..."
fingerprint      = "12:34:56:78:90:ab:cd:ef:..."
private_key      = <<EOT
-----BEGIN PRIVATE KEY-----
...paste-your-oci-api-private-key...
-----END PRIVATE KEY-----
EOT
region           = "eu-frankfurt-1"
compartment_ocid = "ocid1.tenancy.oc1..aaaa..."

ssh_public_key      = "ssh-ed25519 AAAA... yourname@host"
ssh_allowed_cidr    = "0.0.0.0/0"

# 3 nodes total = 1 server + 2 agents, each 1 OCPU / 6 GB (= 3 OCPU / 18 GB).
# If capped at 2 OCPU / 12 GB, set agent_count = 1 (2 nodes total).
agent_count         = 2
instance_ocpus      = 1
instance_memory_gbs = 6

expose_http = true
