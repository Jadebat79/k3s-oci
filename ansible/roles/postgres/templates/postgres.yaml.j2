apiVersion: v1
kind: Namespace
metadata:
  name: {{ pg_namespace }}
---
apiVersion: v1
kind: Secret
metadata:
  name: pg-secret
  namespace: {{ pg_namespace }}
type: Opaque
stringData:
  POSTGRES_USER: "{{ pg_user }}"
  POSTGRES_PASSWORD: "{{ pg_password }}"
  POSTGRES_DB: "{{ pg_db }}"
---
apiVersion: v1
kind: Service
metadata:
  name: postgres
  namespace: {{ pg_namespace }}
spec:
  clusterIP: None
  selector:
    app: postgres
  ports:
    - port: 5432
      targetPort: 5432
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: postgres
  namespace: {{ pg_namespace }}
spec:
  serviceName: postgres
  replicas: 1
  selector:
    matchLabels:
      app: postgres
  template:
    metadata:
      labels:
        app: postgres
    spec:
      nodeSelector:
        role: database
      containers:
        - name: postgres
          image: {{ pg_image }}
          envFrom:
            - secretRef:
                name: pg-secret
          ports:
            - containerPort: 5432
          resources:
            requests:
              cpu: "250m"
              memory: "512Mi"
            limits:
              cpu: "1"
              memory: "2Gi"
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
              subPath: pgdata
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes: ["ReadWriteOnce"]
        storageClassName: local-path
        resources:
          requests:
            storage: {{ pg_storage_size }}
{% if pg_backup_par_url | length > 0 %}
---
apiVersion: batch/v1
kind: CronJob
metadata:
  name: pg-backup
  namespace: {{ pg_namespace }}
spec:
  schedule: "{{ pg_backup_schedule }}"
  jobTemplate:
    spec:
      template:
        spec:
          restartPolicy: OnFailure
          containers:
            - name: dump
              image: {{ pg_image }}
              envFrom:
                - secretRef:
                    name: pg-secret
              env:
                - name: PAR_URL
                  value: "{{ pg_backup_par_url }}"
              command:
                - /bin/sh
                - -c
                - >
                  pg_dump -h postgres -U "$POSTGRES_USER" "$POSTGRES_DB"
                  | gzip
                  | curl -s -T - "${PAR_URL}{{ pg_db }}-$(date +%F).sql.gz"
{% endif %}
